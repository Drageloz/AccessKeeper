{
  "manifest_version": 3,
  "name": "Access Keeper",
  "version": "1.0.0",
  "description": "Mantiene activos y visibles los accesos del equipo",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
